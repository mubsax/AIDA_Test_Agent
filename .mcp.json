{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--browser=chromium",
        "--viewport-size=1440,900",
        "--storage-state=auth.json",
        "--ignore-https-errors"
      ]
    },
    "context": {
      "command": "python",
      "args": ["context_server/server.py"]
    }
  }
}