# ─────────────────────────────────────────────────────────────
# AI Test Agent — environment variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git — only commit .env.example
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────


# ── App under test ────────────────────────────────────────────

# Base URL of the application (no trailing slash)
APP_URL=https://your-app.com

# Path to the login page
LOGIN_PATH=/login

# Path the app redirects to after successful login
POST_LOGIN_PATH=/dashboard


# ── Test account credentials ──────────────────────────────────

# Use a dedicated QA service account — not a real user account
TEST_EMAIL=qa-agent@your-app.com
TEST_PASSWORD=your-test-password


# ── Session state ─────────────────────────────────────────────

# Where save_auth.py writes the browser session file
# This path must match --storage-state in .mcp.json
AUTH_PATH=auth.json


# ── Confluence (optional) ─────────────────────────────────────

# Leave blank if you are not using Confluence as a context source.
# The context server will skip Confluence silently if these are unset.

CONFLUENCE_EMAIL=you@your-org.com
CONFLUENCE_API_TOKEN=

# Your Atlassian org subdomain (e.g. your-org → your-org.atlassian.net)
CONFLUENCE_ORG=your-org

# Default Confluence space key to pull pages from (optional)
CONFLUENCE_SPACE_KEY=QA


# ── Playwright MCP ────────────────────────────────────────────

# Browser to use: chromium | firefox | webkit
PLAYWRIGHT_BROWSER=chromium

# Viewport size passed to the MCP server
PLAYWRIGHT_VIEWPORT=1440,900

# Set to true in CI to run headless
CI=false


# ── Reporting ─────────────────────────────────────────────────

# Directory where test reports and screenshots are written
REPORTS_DIR=reports

# Directory where agent-generated test files are saved
GENERATED_TESTS_DIR=tests/generated